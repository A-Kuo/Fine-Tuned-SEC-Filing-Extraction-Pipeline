# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ─── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/

# ─── IDE ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace

# ─── Cursor IDE ───────────────────────────────────────────────────────────────
# Keep .cursor/CLAUDE.md (project agent context) but exclude installed skills
# and any personal IDE config that doesn't belong in the project repo
.cursor/skills/
.cursor/rules/

# ─── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/
.mypy_cache/

# ─── Project Artifacts ───────────────────────────────────────────────────────
# Model weights and checkpoints (large binary files)
models/
!models/.gitkeep
results/
!results/.gitkeep

# Generated data (reproducible via scripts/download_dataset.py + format_data.py)
data/*.jsonl
# Keep sample reference files
!data/sample_10k.txt
!data/sample_10k.expected.json

# EDGAR downloads (reproducible via scripts/fetch_edgar.py)
data/raw_edgar/

# ─── Secrets ─────────────────────────────────────────────────────────────────
.env

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
